{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "app/**", "prisma/**", "vite.config.ts", "tsconfig.json", "package.json"],
      "outputs": ["build/**", "dist/**", ".react-router/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "app/**", "tsconfig.json", "package.json"]
    },
    "lint": {
      "inputs": ["src/**", "app/**", "*.ts", "*.tsx", "*.js"]
    },
    "lint:fix": {
      "inputs": ["src/**", "app/**", "*.ts", "*.tsx", "*.js"]
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "inputs": ["src/**", "app/**", "*.ts", "*.tsx", "*.js"]
    },
    "clean": {
      "cache": false
    }
  }
}
